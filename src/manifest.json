{
  "manifest_version": 3,
  "name": "Dev Password Helper",
  "description": "Store and autofill development environment passwords with a minimal popup and options page.",
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Dev Password Helper",
    "default_icon": "icon-34.png"
  },
  "icons": {
    "128": "icon-128.png"
  },
  "permissions": ["storage", "activeTab", "scripting"]
}
